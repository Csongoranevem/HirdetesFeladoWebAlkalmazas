### get all adverts

GET http://localhost:3000/adverts/
Content-Type: application/json

### get advert by id
GET http://localhost:3000/adverts/647507b2-8cd8-4b93-a3c6-9898f52ecfb7
Content-Type: application/json


### create advert
POST http://localhost:3000/adverts/
Content-Type: application/json

{
    "name": "Test Advert 7",
    "description": "This is a test advert.",
    "user_id": "fab5b050-16af-45f8-b0c8-356e62bf5ae0",
    "price": 100,
    "city_id": "Söréd",
    "product_id": "TElefon",
    "category_id": 1,
    "payment_method": 1,
    "status": "active"
}


### update advert by id
PATCH http://localhost:3000/adverts/647507b2-8cd8-4b93-a3c6-9898f52ecfb7
Content-Type: application/json

{
    "name": "Updated Test Advert"
}


### delete advert by id
DELETE http://localhost:3000/adverts/647507b2-8cd8-4b93-a3c6-9898f52ecfb7
